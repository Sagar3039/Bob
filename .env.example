# Copy this file to ".env" (same folder) and fill in your real key.
# .env is already gitignored — never commit real secrets.

# Get this from https://app.composio.dev  (Settings -> API Keys)
COMPOSIO_API_KEY=

# Optional: the Composio user id these tool connections are scoped to.
# Defaults to a shared test id if omitted — set your own so your connected
# accounts (Gmail, Google Tasks, Drive, etc.) are private to you.
COMPOSIO_USER_ID=
